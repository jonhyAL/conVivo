    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const horarioRadios = document.querySelectorAll('.horario-radio');
            const submitBtn = document.getElementById('submit-btn');
            const especialistaInput = document.getElementById('especialista_id');
            const horarioInput = document.getElementById('horario_id');

            console.log('Horarios encontrados:', horarioRadios.length);

            horarioRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    // Uncheck all other radios (optional, but handled by radio name)
                    
                    if (this.checked) {
                        horarioInput.value = this.value;
                        especialistaInput.value = this.dataset.especialista;
                        
                        // Enable button with styles
                        submitBtn.disabled = false;
                        submitBtn.classList.remove('bg-gray-200', 'text-gray-400', 'cursor-not-allowed', 'shadow-sm');
                        submitBtn.classList.add('bg-gradient-to-r', 'from-blue-600', 'to-indigo-600', 'text-white', 'shadow-lg', 'shadow-blue-600/30', 'hover:shadow-blue-600/40', 'hover:-translate-y-1', 'cursor-pointer');
                    }
                });
            });

            // Mobile menu toggle
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            if (mobileMenuBtn && mobileMenu) {
                mobileMenuBtn.addEventListener('click', () => {
                    mobileMenu.classList.toggle('hidden');
                });
            }
        });
    </script>

    @include('components.footer')
